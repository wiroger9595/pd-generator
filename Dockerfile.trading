FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app/trading

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir "TA-Lib>=0.4.28" APScheduler

COPY . .

EXPOSE 8002

CMD ["sh", "-c", "cd /app/trading && PYTHONPATH=/app/trading uvicorn app:app --host 0.0.0.0 --port ${PORT:-8002}"]
